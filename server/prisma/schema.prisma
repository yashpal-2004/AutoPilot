generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  preferences     UserPreferences?
  resumes         Resume[]
  jobs            JobPost[]
  applications    Application[]
  notifications   TelegramNotificationConfig?
  automationRuns  AutomationRun[]
}

model UserPreferences {
  id                    String   @id @default(cuid())
  userId                String   @unique
  targetRolesJson       Json
  skillsJson            Json
  locationsJson         Json
  minStipend            Int?
  dailyLimit            Int      @default(5)
  minMatchScore         Int      @default(80)
  avoidKeywordsJson     Json
  blockedCompaniesJson  Json
  remoteOnly            Boolean  @default(false)
  avoidUnpaid           Boolean  @default(true)
  autopilotEnabled      Boolean  @default(false)
  manualApproval        Boolean  @default(true)
  scheduleTime          String   @default("09:00")
  timezone              String   @default("Asia/Kolkata")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Resume {
  id              String   @id @default(cuid())
  userId          String
  name            String
  originalFileUrl String
  parsedText      String?
  skillsJson      Json?
  roleCategory    String?
  pageCount       Int?
  isActive        Boolean  @default(true)
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User @relation(fields: [userId], references: [id])
  applications    Application[]
}

model GeneratedResume {
  id              String   @id @default(cuid())
  resumeId        String
  jobPostId       String
  fileUrl         String
  htmlContent     String?
  pageCount       Int
  validationJson  Json
  createdAt       DateTime @default(now())
}

model JobPost {
  id              String   @id @default(cuid())
  userId          String
  platform        String   @default("internshala")
  companyName     String
  title           String
  location        String?
  stipend         String?
  duration        String?
  skillsJson      Json?
  description     String?
  jobUrl          String
  deadline        DateTime?
  sourceHash      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User @relation(fields: [userId], references: [id])
  applications    Application[]

  @@unique([userId, jobUrl])
}

model Application {
  id                  String            @id @default(cuid())
  userId              String
  jobPostId            String
  resumeId             String?
  matchScore           Int
  scoreBreakdownJson   Json?
  selectedAnswersJson  Json?
  coverLetter          String?
  status               ApplicationStatus @default(FOUND)
  appliedAt            DateTime?
  lastCheckedAt        DateTime?
  replyStatus          String?
  replySummary         String?
  screenshotUrl        String?
  errorMessage         String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User @relation(fields: [userId], references: [id])
  jobPost              JobPost @relation(fields: [jobPostId], references: [id])
  resume               Resume? @relation(fields: [resumeId], references: [id])

  @@unique([jobPostId, userId], name: "jobPostId_userId")
}

enum ApplicationStatus {
  FOUND
  MATCHED
  READY_FOR_REVIEW
  APPROVED
  APPLIED
  SEEN
  REPLIED
  INTERVIEW
  REJECTED
  ERROR
  SKIPPED
  BLACKLISTED
}

model AutomationRun {
  id              String   @id @default(cuid())
  userId          String
  mode            String
  targetCount     Int
  appliedCount    Int      @default(0)
  skippedCount    Int      @default(0)
  errorCount      Int      @default(0)
  status          String
  logsJson        Json?
  startedAt       DateTime @default(now())
  finishedAt      DateTime?

  user            User @relation(fields: [userId], references: [id])
}

model TelegramNotificationConfig {
  id                    String   @id @default(cuid())
  userId                String   @unique
  telegramEnabled       Boolean  @default(false)
  telegramBotTokenEnc   String?
  telegramChatIdEnc     String?
  dailySummary          Boolean  @default(true)
  instantApplicationAlerts Boolean @default(false)
  instantReplyAlerts    Boolean  @default(true)
  errorAlerts           Boolean  @default(true)

  user                  User @relation(fields: [userId], references: [id])
}
